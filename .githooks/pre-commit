#!/bin/sh
set -e

if ! command -v clang-format >/dev/null 2>&1; then
  echo "clang-format not found; skipping formatting"
  exit 0
fi

FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\\.(c|cc|cpp|cxx|h|hh|hpp|m|mm)$' | grep -v '^third_party/' || true)
if [ -z "$FILES" ]; then
  echo "No C/C++/ObjC++ files staged (excluding third_party); skipping clang-format"
  exit 0
fi

echo "Running clang-format on staged files"
for f in $FILES; do
  clang-format -i "$f"
  git add "$f"
done
